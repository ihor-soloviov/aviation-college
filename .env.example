MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your-mysql-database

# Path to the uploads directory.
# In `local` upload mode this is where Next.js writes uploaded files and serves them from.
# In `remote` upload mode this is read-only — the files-api owns writes.
UPLOADS_DIR=/var/www/uploads

# Base URL of aviation-files-api. Used both for legacy file proxy and uploaded image hosting.
FILES_API_URL=http://localhost:3001
NEXT_PUBLIC_FILES_API_URL=http://localhost:3001

# Upload backend selector:
#   remote — POSTs to FILES_API_URL/api/uploads/image (current production setup)
#   local  — writes directly to UPLOADS_DIR via fs (after the server upgrade)
UPLOAD_MODE=remote

# Shared secret for authenticating against aviation-files-api uploads.
# Must match FILES_API_UPLOAD_TOKEN on the files-api side. Required when UPLOAD_MODE=remote.
FILES_API_UPLOAD_TOKEN=replace-with-strong-random-secret

# === Payload CMS ===
# JWT secret. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=
# SQLite file URL (libsql). Default is fine for local dev.
DATABASE_URI=file:./data/payload/cms.sqlite
