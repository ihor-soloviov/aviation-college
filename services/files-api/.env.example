PORT=3001
UPLOADS_DIR=/var/www/uploads

# Comma-separated list of allowed CORS origins.
# Defaults to http://localhost:3000 if unset.
CORS_ORIGINS=http://localhost:3000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your-mysql-database

# Shared secret used by aviation-college server to authenticate upload requests.
# Generate with: openssl rand -hex 32
FILES_API_UPLOAD_TOKEN=a7a7c8abde912235aa85fa0ebfe73c9cd0bbeac157589c195cc6ee22d8e7396f
