# Скопіювати в .env.production на сервері та заповнити.
# .env.production у git не лежить (.gitignore містить .env*).

# === MySQL ===
MYSQL_ROOT_PASSWORD=__GENERATE_STRONG__
MYSQL_DATABASE=aviation
MYSQL_USER=aviation
MYSQL_PASSWORD=__GENERATE_STRONG__

# === Files API ===
# SSR-доступ із контейнера next йде у внутрішню мережу docker напряму:
FILES_API_URL=http://files-api:3001
# Клієнтський (браузерний) доступ — через nginx (поки немає домену, ставимо IP):
NEXT_PUBLIC_FILES_API_URL=http://204.168.161.68
FILES_API_UPLOAD_TOKEN=
# Дозволені CORS origins для files-api (через кому):
CORS_ORIGINS=http://localhost:3000,http://204.168.161.68

# === Public site URL (для абсолютних посилань у sitemap/OG) ===
NEXT_PUBLIC_SITE_URL=

# === PayloadCMS ===
# Згенерувати: openssl rand -hex 32
PAYLOAD_SECRET=__GENERATE_STRONG__
# SQLite-файл живе у bind-mount ./data/payload/ (відносно /app у контейнері):
DATABASE_URI=file:./data/payload/cms.sqlite
